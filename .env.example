# ============================================================
# AI SCADA Platform — Environment Variables Template
# ============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── InfluxDB ───────────────────────────────────────────────
INFLUX_TOKEN=your-influxdb-token-here
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=your-secure-password
INFLUXDB_ORG=ELECSOL
INFLUXDB_BUCKET=ELEC1

# ── MQTT ───────────────────────────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883
# MQTT_USER=
# MQTT_PASS=

# ── Authentication ─────────────────────────────────────────
AUTH_SECRET_KEY=change-this-to-a-random-secret-key
ADMIN_PASSWORD=admin123

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
